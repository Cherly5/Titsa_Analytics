# Google Cloud
GOOGLE_CLOUD_PROJECT=
PUBSUB_DATAFLOW_SUBSCRIPTION=
PUBSUB_WEBSOCKET_SUBSCRIPTION=

# Mapbox
MAPBOX_ACCESS_TOKEN=pk...

# WebSocket
WS_HOST=localhost
WS_PORT=8765
WS_URL=ws://localhost:8765

# API (if needed)
API_KEY=gc_api_key_here
BASE_URL=https://api.example.com

# HTTP Server
HTTP_PORT=8000

# Pub/Sub Topics
TOPIC_VEHICLES=
TOPIC_TRIPS=
TOPIC_ALERTS=

# BigQuery
BQ_DATASET=titsa_dataset
BQ_TABLE_VEHICLES=vehicle_positions
BQ_TABLE_TRIPS=trip_updates
VEHICLE_SCHEMA=event_id:STRING,type:STRING,vehicle_id:STRING,label:STRING,trip_id:STRING,start_time:STRING,start_date:STRING,schedule_relationship:INTEGER,route_id:STRING,lat:FLOAT,lon:FLOAT,bearing:FLOAT,odometer:FLOAT,speed_mps:FLOAT,speed_kmh:FLOAT,current_stop_sequence:INTEGER,current_status:INTEGER,timestamp:TIMESTAMP,stop_id:STRING,ingested_at:TIMESTAMP,latency_seconds:FLOAT
TRIP_SCHEMA=event_id:STRING,type:STRING,trip_id:STRING,start_time:STRING,start_date:STRING,schedule_relationship:INTEGER,route_id:STRING,stop_id:STRING,stop_sequence:INTEGER,arrival_time:TIMESTAMP,event_time:TIMESTAMP,delay:INTEGER,vehicle_id:STRING,vehicle_label:STRING,timestamp:TIMESTAMP,ingested_at:TIMESTAMP

# FEED URLs
URL_VEHICLES=
URL_TRIPS=
URL_ALERTS=

# Poll Intervals (in seconds)
POLL_INTERVAL_VEHICLES=30
POLL_INTERVAL_TRIPS=30
POLL_INTERVAL_ALERTS=300

# Configuration
BEARING_USE=false
INTERPOLATION_USE=true